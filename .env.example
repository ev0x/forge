# Copy this file to `.env` and fill in real values.
# `docker compose` will load whatever is in `.env` automatically.

# --- Database ---
POSTGRES_USER=tz
POSTGRES_PASSWORD=change-me-before-running
POSTGRES_DB=forge

# --- Host ports (change if you have something else on these) ---
POSTGRES_PORT=5433
API_PORT=8088
WEB_PORT=5180

# --- Optional: Sierra Chart Data folder bind-mount ---
# Absolute path to your local Sierra Chart Data folder so the api can read .scid
# (tick history) and .data (TradeAccount snapshots) directly. Leave commented
# to disable. Examples:
#   macOS Wine:                   SIERRA_DATA=/Users/you/.wine/drive_c/SierraChart/Data
#   Network share mounted on Mac: SIERRA_DATA=/Volumes/sierra/Data
# SIERRA_DATA=/path/to/SierraChart/Data
